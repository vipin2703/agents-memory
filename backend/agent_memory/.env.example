# Agent memory stores (backend container). Copy → .env or merge into vllm/.env

# Postgres — source of truth (schema via memory-migrate)
MEMORY_DATABASE_URL=postgresql://postgresuser:CHANGE_ME@postgres:5432/agent_memory

# Elasticsearch — BM25 + dense_vector (schema via elasticsearch-migrate)
MEMORY_ELASTICSEARCH_URL=http://elasticsearch:9200
MEMORY_ELASTICSEARCH_INDEX=agent_memory_messages

# Neo4j — knowledge graph (backend app client)
# Compose neo4j/graphxr services use config/.env (same user/pass rakho)
# Schema via neo4j-migrate (not app)
MEMORY_NEO4J_URI=bolt://neo4j:7687
MEMORY_NEO4J_USER=neo4j
MEMORY_NEO4J_PASSWORD=agentmemory
